<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nav_graph"
    app:startDestination="@id/listaCrimenesFragment">

    <fragment
        android:id="@+id/listaCrimenesFragment"
        android:name="com.example.registrocriminal.ListaCrimenesFragment"
        android:label="CrimenesFragment"
        tools:layout="@layout/fragment_lista_crimenes">

        <action
            android:id="@+id/mostrar_crimen"
            app:destination="@id/crimenFragment" />
    </fragment>

    <fragment
        android:id="@+id/crimenFragment"
        android:name="com.example.registrocriminal.CrimenFragment"
        android:label="CrimenFragment"
        tools:layout="@layout/fragment_crimen">

        <argument
            android:name="crimenId"
            app:argType="java.util.UUID" />

        <action
            android:id="@+id/selectorFecha"
            app:destination="@id/datePickerFragment" />

        <action
            android:id="@+id/selectorTiempo"
            app:destination="@id/timePickerFragment" />

    </fragment>

    <dialog
        android:id="@+id/datePickerFragment"
        android:name="com.example.registrocriminal.DatePickerFragment"
        android:label="DatePickerFragment">
        <argument
            android:name="fechaCrimen"
            app:argType="java.util.Date" />
    </dialog>

    <dialog
        android:id="@+id/timePickerFragment"
        android:name="com.example.registrocriminal.TimePickerFragment"
        android:label="TimePickerFragment">
        <argument
            android:name="fechaCrimen"
            app:argType="java.util.Date" />
    </dialog>

</navigation>